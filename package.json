{
  "name": "azure-devops-extensions",
  "scripts": {
    "prepare": "git fetch origin main",
    "changeset": "changeset",
    "typecheck": "tsc --build --emitDeclarationOnly",
    "test": "vitest",
    "prebuild": "pnpm --filter ./packages/* exec tsc --build",
    "build": "pnpm --filter '...{extensions}[origin/main]' exec node ../../tools/build-tasks.mjs",
    "package": "pnpm --filter '...{extensions}[origin/main]' exec tfx extension create --manifest-js vss-extension.js",
    "publish": "pnpm --filter '...{extensions}[origin/main]' exec tfx extension publish --manifest-js vss-extension.js --auth-type pat --token $ENTRA_TOKEN"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm biome check --fix"
  },
  "dependencies": {
    "azure-pipelines-task-lib": "^5.2.8",
    "azure-pipelines-tool-lib": "^2.0.12",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "glob": "^13.0.6",
    "simple-git-hooks": "^2.13.1",
    "tfx-cli": "^0.23.1",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
