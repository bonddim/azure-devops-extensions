{
  "name": "azure-devops-extensions",
  "scripts": {
    "prepare": "git fetch origin main",
    "changeset": "changeset",
    "typecheck": "tsc --build --emitDeclarationOnly",
    "test": "vitest",
    "build": "pnpm  --filter ...[${PNPM_BASE:-origin/main}] --if-present run build",
    "package": "pnpm --filter ...[${PNPM_BASE:-origin/main}] --if-present run package",
    "publish": "pnpm --filter ...[${PNPM_BASE:-origin/main}] --if-present run publish"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm biome check --fix"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "azure-pipelines-task-lib": "^5.2.8",
    "azure-pipelines-tool-lib": "^2.0.12",
    "semver": "^7.7.4",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^24.12.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "simple-git-hooks": "^2.13.1",
    "tfx-cli": "^0.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vitest-sonar-reporter": "^3.0.0"
  }
}
